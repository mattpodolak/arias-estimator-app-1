# ARIAS Estimator — environment variables
# Copy to `.env.local` for local dev, or set in your hosting provider for prod.

# ----------------------------------------------------------------------------
# Plan extraction backend
# ----------------------------------------------------------------------------
# Selects the backend used by /api/extract.
#   guild  — call the Guild AI extraction service (default in production)
#   gemini — call Google Gemini directly (legacy / fallback)
# If unset, the server picks `guild` when GUILD_API_KEY is present, otherwise
# falls back to `gemini` if GEMINI_API_KEY is present.
EXTRACTOR_BACKEND=guild

# ----------------------------------------------------------------------------
# Guild AI (preferred backend)
# ----------------------------------------------------------------------------
# API key issued by Guild for server-to-server calls.
GUILD_API_KEY=

# Override the Guild extraction endpoint. Defaults to:
#   https://agents.joinguild.ai/api/extract
GUILD_API_URL=

# ----------------------------------------------------------------------------
# Google Gemini (legacy / fallback backend)
# ----------------------------------------------------------------------------
# Only required when EXTRACTOR_BACKEND=gemini.
GEMINI_API_KEY=
